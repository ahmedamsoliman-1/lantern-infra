# Copy to .env only on lantern-core. Never commit .env.
LANTERN_DOMAIN=home.arpa
# Current hotspot DHCP leases; update these if the hotspot reassigns them.
LANTERN_CORE_IP=192.168.102.253
WINDOWS_LAN_IP=192.168.102.40
# Trusted private client range. This tolerates hotspot changes between
# 192.168.x.0/24 networks without exposing services outside private LAN space.
LAN_SUBNET=192.168.0.0/16
TZ=Asia/Dubai

# Explicitly pinned, reviewed image versions.
CADDY_IMAGE=caddy:2.11.4
HOMEPAGE_IMAGE=ghcr.io/gethomepage/homepage:v1.13.1
UPTIME_KUMA_IMAGE=louislam/uptime-kuma:2.3.2
PIHOLE_IMAGE=pihole/pihole:2026.07.2
RUSTDESK_SERVER_IMAGE=rustdesk/rustdesk-server:1.1.15-amd64@sha256:696eeb859a7191e95eca697e5fbfffaaffa47dc4f8b339dad1a35312b7b6972e
UPSTREAM_DNS=192.168.102.124
