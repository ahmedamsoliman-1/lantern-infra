{
	admin off
}

(common) {
	encode zstd gzip
	header {
		X-Content-Type-Options nosniff
		X-Frame-Options SAMEORIGIN
		Referrer-Policy no-referrer
	}

	tls internal
}

# HTTP-only emergency dashboard access when client DNS is unavailable.
http://{$LANTERN_CORE_IP} {
	encode zstd gzip
	header {
		X-Content-Type-Options nosniff
		X-Frame-Options SAMEORIGIN
		Referrer-Policy no-referrer
	}
	reverse_proxy homepage:3000
}

dashboard.home.arpa {
	import common
	reverse_proxy homepage:3000
}

status.home.arpa {
	import common
	reverse_proxy uptime-kuma:3001
}

dns.home.arpa {
	import common
	reverse_proxy pihole:80
}

photos.home.arpa {
	import common
	reverse_proxy {$WINDOWS_LAN_IP}:2283
}
